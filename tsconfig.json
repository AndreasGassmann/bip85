{
    "compilerOptions": {
        "target": "es2022",
        "module": "node16",
        "moduleResolution": "node16",
        "outDir": "./src",
        "declaration": true,
        "declarationDir": "./types",
        "rootDir": "./ts_src",
        "types": [
            "node"
        ],
        "allowJs": false,
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictBindCallApply": true,
        "strictPropertyInitialization": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "esModuleInterop": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "resolveJsonModule": true
    },
    "include": [
        "ts_src/**/*.ts",
    ],
    "exclude": [
        "**/*.spec.ts",
        "node_modules/**/*"
    ]
}